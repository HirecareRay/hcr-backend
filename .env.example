# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다 (cp .env.example .env)
# .env 는 깃에 올리지 않는다.

APPNAME=HCR Backend
DEBUG=true

# 프론트 개발 서버 주소
FRONTENDORIGIN=http://localhost:3000

# DB 연동 단계에서 사용 예정
# MARIADBURL=mysql+pymysql://user:password@EC2주소:3306/hcr
# MONGODBURI=mongodb://EC2주소:27017

# LLM 연동 단계에서 사용 예정
# OPENAIAPIKEY=sk-...
