# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다 (cp .env.example .env)
# .env 는 깃에 올리지 않는다.

APP_NAME=HCR Backend
DEBUG=true

# 프론트 개발 서버 주소
FRONTEND_ORIGIN=http://localhost:3000

# DB 연동 (값을 비워두면 해당 DB 비활성 — 서버는 그대로 기동)
# 맥에서는 SSH 터널 경유: 127.0.0.1:13306(MariaDB)·37017(Mongo)
MARIADB_URL=mysql+pymysql://user:password@EC2주소:3306/hcr
MONGODB_URI=mongodb://EC2주소:27017
MONGODB_DB_NAME=hcr

# 인증(JWT) — 시크릿은 각자 .env 에만 채운다(아래는 형식 예시)
# 예: openssl rand -hex 32 로 생성한 임의 문자열
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 소셜 로그인(OAuth) — 카카오·구글·네이버. 각 provider 콘솔에서 발급한 값을 각자
# .env 에만 채운다(client_secret 은 시크릿 — 코드·example 에 실제 값 X). redirect_uri
# 는 환경별로 다르게 채운다: 로컬은 아래 localhost, 운영 .env 는 vercel 도메인으로.
#   로컬:  http://localhost:3000/api/auth/callback/{provider}
#   운영:  https://hcr-web-brown.vercel.app/api/auth/callback/{provider}
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

# LLM·STT(OpenAI) — 각자 .env 에만 실제 키를 채운다
OPENAI_API_KEY=sk-...

# TTS(면접관 음성) — ElevenLabs 백엔드 중계. 각자 .env 에만 실제 키를 채운다.
#  INTERVIEW_TTS_ENABLED=false(기본)면 엔드포인트 비활성 → 프론트 SpeechSynthesis(무료)로 폴백.
#  true 로 켜야 과금 경로가 열린다. 모델은 저지연·저가 flash 고정. 텍스트 상한으로 과금 방어.
ELEVENLABS_API_KEY=
INTERVIEW_TTS_ENABLED=false
ELEVENLABS_MODEL=eleven_flash_v2_5
INTERVIEW_TTS_MAX_CHARS=600
#  페르소나별 목소리·발화 속도 — 안 채우면 코드 기본값 사용(인사=여성, 기술=남성,
#  실무=여성 / speed 0.88 로 느리게). 목소리·속도를 바꾸려면 아래처럼 JSON 으로 넣는다
#  (코드 수정 없이 튜닝). speed 0.7~1.2(1.0=기본, 낮을수록 느림), voice_id 는 ElevenLabs
#  Voice Library 에서 고른 값. 일부 페르소나만 넣어도 되고, 나머지는 기본값이 쓰인다.
#  INTERVIEW_TTS_VOICES={"culture_fit":{"voice_id":"EXAVITQu4vr4xnSDxMaL","speed":0.88},"tech_pressure":{"voice_id":"aQzFKIjVemqRAhfd9est","speed":0.88},"practical":{"voice_id":"zgDzx5jLLCqEp6Fl7Kl7","speed":0.88}}
#  볼륨 정규화 — 목소리마다 원본 음량이 달라 담당별 크기가 제각각이라, 합성 후 ffmpeg
#  loudnorm 으로 균일화한다(기본 켜짐). ⚠️ 배포 서버에 ffmpeg 필요(없으면 자동 건너뜀).
#  target_lufs 는 목표 음량(-30~-9, 낮을수록 조용, 방송기준 -16 근처 권장).
INTERVIEW_TTS_NORMALIZE=true
INTERVIEW_TTS_TARGET_LUFS=-16.0

# 면접 자막 모드
#  false(기본): answer_end 에 누적 오디오를 gpt-4o-mini-transcribe 로 한 번에 전사(실 STT, 과금)
#  true        : 오디오 청크마다 더미 부분 자막을 흘림(OpenAI 호출 0, 자막이 흐르는
#                실시간 UX 시연용 — 키 없이도 동작)
INTERVIEW_DUMMY_TRANSCRIPT=false

# 면접 실시간 부분 자막(실 STT) 모드
#  false(기본): answer_end 에 한 번만 전사(배치)
#  true        : 답변 중 누적 오디오를 N청크마다 재전사해 부분 자막을 흘림
#                (말하면서 자막이 차오르는 UX). ⚠️ 호출 반복 → 과금 증가 주의
#  ※ 더미 모드가 켜져 있으면 그쪽이 우선이라 이 설정은 무시됨
INTERVIEW_PARTIAL_TRANSCRIPT=false
#  부분 자막 재전사 간격(오디오 청크 N개마다 1회). 작을수록 자주 갱신·비용↑ (1~50)
INTERVIEW_PARTIAL_TRANSCRIPT_EVERY=8

# 면접 WS 입장 티켓 TTL(초) — 브라우저 WS 는 헤더를 못 붙이므로 JWT 대신 단기·1회용
# 티켓을 쿼리로 받는다. 짧을수록 URL 노출 위험↓, 너무 짧으면 발급↔연결 지연에 걸림 (10~300)
INTERVIEW_WS_TICKET_TTL_SECONDS=60

# 면접 WS 허용 Origin 목록(콤마 구분) — CSWSH 방어. WS 엔 CORS 가 안 먹으므로 서버가
# 핸드셰이크의 Origin 헤더를 직접 검사한다. ⚠️ 운영에선 반드시 실제 프론트 도메인을
# 채운다 — 비우면 개발 모드로 로컬 프론트(localhost:3000)만 허용한다.
# 예: INTERVIEW_ALLOWED_ORIGINS=https://hcr.example.com,https://www.hcr.example.com
INTERVIEW_ALLOWED_ORIGINS=

# 인기기업 순위(랭킹/trending) — 리포트 조회수를 회사·날짜별로 누적해 최근 N 일 합산으로
# 순위를 낸다. 윈도우(일): '오늘만'(=1)은 자정에 비고 새벽엔 순위가 출렁이므로 기본 7일
# 롤링으로 안정화한다(1~30). 노출 개수는 기본 5개(1~20).
RANKING_TRENDING_WINDOW_DAYS=7
RANKING_TRENDING_DEFAULT_LIMIT=5
# 로고 베이스 — website_url 도메인으로 Google favicon URL(f"{base}?domain={d}&sz={n}")을 만든다.
# 비우면 자동 로고 산출을 끄고 큐레이션 logo_url 만 쓴다(외부 의존 차단 스위치).
RANKING_LOGO_CDN_BASE=https://www.google.com/s2/favicons
# favicon 요청 크기(px, 16~256) — 프론트 로고 원에 맞춰 업스케일.
RANKING_LOGO_SIZE=128
