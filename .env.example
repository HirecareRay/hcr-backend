# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다 (cp .env.example .env)
# .env 는 깃에 올리지 않는다.

# ========================
# FastAPI
# ========================

APP_NAME=HCR Backend

# 개발: true / 운영: false
DEBUG=true

# dev | prod
ENV=dev

# 허용할 프론트 Origin (콤마 구분)
# 로컬:
#   http://localhost:3000
# 운영:
#   https://hcr-web-brown.vercel.app
FRONTEND_ORIGINS=http://localhost:3000

# ========================
# Database
# ========================

# DB 연동 (값을 비워두면 해당 DB 비활성 — 서버는 그대로 기동)

# ------------------------
# MariaDB
# ------------------------

MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=hcr
MARIADB_USER=
MARIADB_PASSWORD=

# Docker 내부
# mysql+pymysql://user:password@mariadb:3306/hcr
#
# 로컬 SSH 터널 예시
# mysql+pymysql://user:password@127.0.0.1:13306/hcr
#
# EC2 직접 연결 예시
# mysql+pymysql://user:password@<EC2_IP>:3306/hcr
MARIADB_URL=mysql+pymysql://user:password@mariadb:3306/hcr

# ------------------------
# MongoDB
# ------------------------

MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# Docker 내부
# mongodb://root:password@mongo:27017/?authSource=admin
#
# 로컬 SSH 터널
# mongodb://root:password@127.0.0.1:37017/?authSource=admin
#
# EC2 직접 연결
# mongodb://root:password@<EC2_IP>:27017/?authSource=admin
MONGODB_URI=mongodb://root:password@mongo:27017/?authSource=admin

MONGODB_DB_NAME=hcr

# ========================
# Authentication (JWT)
# ========================

# 시크릿은 각자 .env 에만 채운다.
# 예: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========================
# OAuth
# ========================
#
# client_secret 은 절대 Git에 올리지 않는다.
#
# redirect_uri
#
# 로컬
#   http://localhost:3000/api/auth/callback/{provider}
#
# 운영
#   https://hcr-web-brown.vercel.app/api/auth/callback/{provider}
#

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

# ========================
# OpenAI
# ========================

OPENAI_API_KEY=

# ========================
# ElevenLabs TTS
# ========================

# 각자 .env 에만 실제 키를 채운다.
#
# INTERVIEW_TTS_ENABLED=false(기본)
# → 프론트 SpeechSynthesis 사용(무료)
#
# true
# → ElevenLabs 사용(과금 발생)

ELEVENLABS_API_KEY=

INTERVIEW_TTS_ENABLED=false
ELEVENLABS_MODEL=eleven_flash_v2_5
INTERVIEW_TTS_MAX_CHARS=600

# 페르소나별 Voice 설정(JSON)
#
# INTERVIEW_TTS_VOICES={"culture_fit":{"voice_id":"EXAVITQu4vr4xnSDxMaL","speed":0.88},"tech_pressure":{"voice_id":"aQzFKIjVemqRAhfd9est","speed":0.88},"practical":{"voice_id":"zgDzx5jLLCqEp6Fl7Kl7","speed":0.88}}

INTERVIEW_TTS_NORMALIZE=true
INTERVIEW_TTS_TARGET_LUFS=-16.0

# ========================
# Interview STT
# ========================

# false
#   answer_end 에 한 번만 STT 수행
#
# true
#   답변 중 부분 자막 생성
INTERVIEW_DUMMY_TRANSCRIPT=false

INTERVIEW_PARTIAL_TRANSCRIPT=false

# 부분 자막 재전사 간격
INTERVIEW_PARTIAL_TRANSCRIPT_EVERY=8

# ========================
# Interview WebSocket
# ========================

# WS 입장 티켓 TTL(초)
INTERVIEW_WS_TICKET_TTL_SECONDS=60

# WS Origin allowlist (콤마 구분)
#
# 비우면 개발 모드(localhost)만 허용
#
# 운영 예시
# INTERVIEW_ALLOWED_ORIGINS=https://hcr-web-brown.vercel.app
INTERVIEW_ALLOWED_ORIGINS=

# ========================
# Company Ranking
# ========================

# 최근 N일 기준 인기기업 집계
RANKING_TRENDING_WINDOW_DAYS=7

# 기본 노출 개수
RANKING_TRENDING_DEFAULT_LIMIT=5

# Google favicon CDN
# 비우면 자동 로고 생성 비활성
RANKING_LOGO_CDN_BASE=https://www.google.com/s2/favicons

# favicon 크기
RANKING_LOGO_SIZE=128